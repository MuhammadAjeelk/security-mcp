{
  "name": "security-mcp",
  "version": "0.6.0",
  "license": "MIT",
  "description": "MCP server for authorized security testing against localhost/staging targets.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/server.js",
  "bin": {
    "security-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.js --external:playwright --external:bullmq --external:ioredis --external:@anthropic-ai/sdk --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:local": "tsx scripts/run-audit.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.2.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "bullmq": "^5.21.0",
    "ioredis": "^5.4.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
