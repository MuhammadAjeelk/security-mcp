MCP_MODE=stdio
MCP_API_KEY=
# Extra staging hostnames allowed by exact name. NOTE: any hostname that
# CONTAINS "staging" (e.g. api.staging.lynsi.net) is already auto-allowed by
# policy — list hosts here only when they lack "staging" in the name.
# An explicit entry here ALSO overrides the prod/production/live block, so add
# a host like staging.live.example.com to deliberately allow it. Hosts with
# those substrings that are NOT listed here stay blocked.
ALLOWED_STAGING_HOSTS=staging.example.com,dev.example.com
SCAN_TIMEOUT_MS=10000
# Total HTTP requests one scan may issue (crawl + discovery + probes share it).
# Raise for thorough audits of large APIs; lower to be gentle.
SCAN_MAX_REQUESTS=150
SCAN_MAX_DEPTH=2
# Wordlist content-discovery: max path candidates probed per scan.
SCAN_WORDLIST_MAX=60
# JS-bundle endpoint extractor: max .js files downloaded per scan.
SCAN_JS_BUNDLE_MAX=15
# Self-registration: max throwaway accounts to create (0 disables it).
SCAN_REGISTER_MAX_ACCOUNTS=2
# Active probing: max distinct routes exercised per scan (was a fixed 10).
# Raise for route-by-route coverage of large APIs (bounded by SCAN_MAX_REQUESTS).
SCAN_PROBE_MAX_TARGETS=40
# Multi-role differential: max routes re-probed per supplied account.
SCAN_ROLE_PROBE_MAX=40
# Brute-force engine (auto-fires only when the rate-limit precheck finds NO
# throttling). Hard ceiling on attempts; default = full 6-digit keyspace.
SCAN_BRUTE_MAX=1000000
SCAN_BRUTE_CONCURRENCY=20
# Requests sent in the rate-limit precheck burst before brute-forcing.
SCAN_RATELIMIT_SAMPLE=20
PROMPT_LOOP_MAX_ITERATIONS=3
REPORTS_DIR=./reports
LLM_PROVIDER=mock
