{
  "mcpServers": {
    "security-mcp": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/server.js"],
      "env": {
        "ALLOWED_STAGING_HOSTS": "",
        "SCAN_TIMEOUT_MS": "10000",
        "SCAN_MAX_REQUESTS": "300",
        "SCAN_MAX_DEPTH": "2",
        "SCAN_WORDLIST_MAX": "60",
        "SCAN_JS_BUNDLE_MAX": "15",
        "SCAN_REGISTER_MAX_ACCOUNTS": "2",
        "SCAN_PROBE_MAX_TARGETS": "40",
        "SCAN_ROLE_PROBE_MAX": "40",
        "PROMPT_LOOP_MAX_ITERATIONS": "3",
        "REPORTS_DIR": "${CLAUDE_PLUGIN_ROOT}/reports",
        "LLM_PROVIDER": "mock"
      }
    }
  }
}
